getgenv().LoopFling = true -- global toggle controllable from UI

local function FlingAllOnce()
	for _, pl in next, Players:GetPlayers() do
		if pl ~= Player then
			if pl.UserId ~= 0 then
				pcall(function()
					SkidFling(pl)
				end)
			end
		end
	end
end

spawn(function()
	while true do
		if getgenv().LoopFling then
			pcall(FlingAllOnce)
			task.wait(2) -- wait 2 seconds between full runs
		else
			task.wait(0.5)
		end
	end
end)

